# Anthropic API key — used by Chunk 2 (scoring) and the Gmail ingestion pipeline
ANTHROPIC_API_KEY=your_key_here

# Database location — defaults to ./rentals.db
DB_PATH=rentals.db

# Local dev port (avoid 5000 on macOS — AirPlay Receiver uses it)
PORT=5001

# Production deployment knobs — leave blank for local dev
# Set FLASK_ENV=production to require SECRET_KEY and disable debug mode.
# SECRET_KEY must be a long random string. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_ENV=
SECRET_KEY=

# Optional HTTP Basic auth. Set both to enable a username+password gate on
# all routes. Leave both blank to disable auth (fine for localhost-only use).
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=
